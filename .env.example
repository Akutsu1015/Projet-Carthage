# ═══════════════════════════════════════════════════
# PROJET CARTHAGE (Next.js) - Configuration
# ═══════════════════════════════════════════════════
# Copiez ce fichier en .env.local et remplissez les valeurs

# ── App URL ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google OAuth (optionnel) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SMTP / Email (optionnel — pour la vérification email) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Projet Carthage <noreply@example.com>

# ── Mistral AI — Chatbot Jérémie Belpois (optionnel) ──
MISTRAL_API_KEY=

# ── Piston (exécution de code) ──
# Par défaut: instance self-hosted locale (voir docker-compose.piston.yml).
# L'API publique emkc.org est whitelist-only depuis le 15/02/2026.
PISTON_URL=http://localhost:2000/api/v2

# ── Sentry (monitoring d'erreurs, optionnel) ──
# Laisser vide pour désactiver complètement Sentry.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# ── Web Push (notifications PWA, optionnel) ──
# Générer une paire VAPID : `npx web-push generate-vapid-keys`
# Laisser vide pour masquer le bouton "Activer les notifications" côté client.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@gamematcher.fr

# ── Cron (déclencheurs server-to-server) ──
# Secret partagé entre le scheduler et /api/cron/*. Laisser vide pour
# désactiver tous les cron endpoints.
CRON_SECRET=

# ── Backups SQLite ──
# Répertoire de stockage + jours de rétention (défaut 14).
BACKUP_DIR=
BACKUP_RETENTION_DAYS=14
